{
  "manifest_version": 3,
  "name": "WebGator",
  "description": "Native Firefox floating navigation bar with mobile touch support and dynamic page color adoption.",
  "version": "9.0",
  "author": "Pro Bandey",

  "action": {
    "default_popup": "wg.popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png"
    }
  },

  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png"
  },

  "permissions": ["storage"],

  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/wg.script.js"],
      "css": ["css/wg.style.css"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "webgator@pro-bandey.com",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
