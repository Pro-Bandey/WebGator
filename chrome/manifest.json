{
  "manifest_version": 3,
  "name": "WebGator",
  "description": "Native Chrome floating navigation bar with dynamic page color adoption and drag-and-drop support.",
  "version": "9.0",
  "author": "MicroResearch Corporation®",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "wg.popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/wg.script.js"],
      "css": ["css/wg.style.css"]
    }
  ]
}
